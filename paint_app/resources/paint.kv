#:import Window kivy.core.window.Window

BoxLayout:
    orientation: 'vertical'
    canvas.before:
        Color:
            rgba: 0.98, 0.98, 0.98, 1 if not Window.is_dark_theme else 0.12, 0.12, 0.12, 1
        Rectangle:
            pos: self.pos
            size: self.size
    
    BoxLayout:
        id: toolbar
        size_hint_y: None
        height: '22dp'  # macOS standard menu height
        spacing: '0dp'
        padding: '0dp'
        canvas.before:
            Color:
                rgba: 0.98, 0.98, 0.98, 1 if not Window.is_dark_theme else 0.2, 0.2, 0.2, 1
            Rectangle:
                pos: self.pos
                size: self.size
            Color:
                rgba: 0.8, 0.8, 0.8, 1 if not Window.is_dark_theme else 0.3, 0.3, 0.3, 1
            Rectangle:
                pos: self.x, self.y
                size: self.width, 1

        # Brush Size Group with modern styling
        BoxLayout:
            orientation: 'horizontal'
            spacing: '6dp'  # Reduced from 8dp
            size_hint_x: None
            width: '300dp'  # Reduced from 320dp
            padding: '6dp'  # Reduced from 8dp
            canvas.before:
                # Main background
                Color:
                    rgba: 0.2, 0.2, 0.2, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [6,]  # Increased radius
                
                # Subtle highlight
                Color:
                    rgba: 1, 1, 1, 0.05
                RoundedRectangle:
                    pos: self.x, self.y + self.height/2
                    size: self.width, self.height/2
                    radius: [6, 6, 0, 0]
            
            Label:
                text: 'Brush Size'
                size_hint_x: None
                width: '80dp'  # Reduced from 90dp
                color: 0.95, 0.95, 0.95, 1  # Brighter text
                font_size: '13sp'  # Reduced from 15sp
                bold: True
            
            Slider:
                id: brush_size
                min: 1
                max: 20
                value: 2
                size_hint_x: None
                width: '190dp'  # Reduced from 200dp
                cursor_size: ('14dp', '14dp')  # Reduced from 16dp
                background_width: '3dp'  # Reduced from 4dp
                on_value: paint_widget.set_line_width(self.value)
                # Modern slider colors
                value_track: True
                value_track_color: 0.4, 0.4, 0.4, 1
                value_track_width: '3dp'  # Reduced from 4dp
                background_color: 0.25, 0.25, 0.25, 1

        # Color Palette Group
        BoxLayout:
            orientation: 'horizontal'
            spacing: '6dp'
            size_hint_x: None
            width: '345dp'
            padding: '3dp'
            canvas.before:
                Color:
                    rgba: 0.2, 0.2, 0.2, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [6,]
                Color:
                    rgba: 1, 1, 1, 0.05
                RoundedRectangle:
                    pos: self.x, self.y + self.height/2
                    size: self.width, self.height/2
                    radius: [6, 6, 0, 0]
            
            Label:
                text: 'Colors'
                size_hint_x: None
                width: '60dp'
                color: 0.95, 0.95, 0.95, 1
                font_size: '13sp'
                bold: True

            # Basic Colors
            Button:
                size_hint: None, None
                size: '24dp', '24dp'
                background_normal: ''
                background_color: 0, 0, 0, 1
                on_release: paint_widget.set_color([0, 0, 0, 1])
            
            Button:
                size_hint: None, None
                size: '24dp', '24dp'
                background_normal: ''
                background_color: 1, 0, 0, 1
                on_release: paint_widget.set_color([1, 0, 0, 1])
            
            Button:
                size_hint: None, None
                size: '24dp', '24dp'
                background_normal: ''
                background_color: 0, 1, 0, 1
                on_release: paint_widget.set_color([0, 1, 0, 1])
            
            Button:
                size_hint: None, None
                size: '24dp', '24dp'
                background_normal: ''
                background_color: 0, 0, 1, 1
                on_release: paint_widget.set_color([0, 0, 1, 1])
            
            Button:
                size_hint: None, None
                size: '24dp', '24dp'
                background_normal: ''
                background_color: 1, 1, 0, 1
                on_release: paint_widget.set_color([1, 1, 0, 1])
            
            Button:
                size_hint: None, None
                size: '24dp', '24dp'
                background_normal: ''
                background_color: 1, 0, 1, 1
                on_release: paint_widget.set_color([1, 0, 1, 1])
            
            Button:
                size_hint: None, None
                size: '24dp', '24dp'
                background_normal: ''
                background_color: 0, 1, 1, 1
                on_release: paint_widget.set_color([0, 1, 1, 1])
            
            Button:
                size_hint: None, None
                size: '24dp', '24dp'
                background_normal: ''
                background_color: 1, 1, 1, 1
                on_release: paint_widget.set_color([1, 1, 1, 1])
            
            # Custom Color Button
            Button:
                size_hint: None, None
                size: '24dp', '24dp'
                text: '+'
                font_size: '20sp'
                background_normal: ''
                background_color: 0.3, 0.3, 0.3, 1
                on_release: app.show_color_picker()
    
    # Canvas
    PaintWidget:
        id: paint_widget
        canvas.before:
            Color:
                rgba: 1, 1, 1, 1  # White background
            Rectangle:
                pos: self.pos
                size: self.size
